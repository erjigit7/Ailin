{
  "name": "ailin-cinema",
  "version": "0.1.0",
  "private": true,
  "description": "Система автоматизации кинотеатра — касса, бар, отчёты, дисплей для гостей",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "dev:api": "npm run start:dev --workspace @ailin/api",
    "dev:web": "npm run dev --workspace @ailin/web",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @ailin/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @ailin/api",
    "db:indexes": "npm run db:indexes --workspace @ailin/api",
    "db:seed": "npm run db:seed --workspace @ailin/api"
  },
  "engines": {
    "node": ">=20"
  }
}
