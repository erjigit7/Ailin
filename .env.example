# --- Database (PostgreSQL) ---
POSTGRES_USER=ailin
POSTGRES_PASSWORD=ailin
POSTGRES_DB=ailin_cinema
# 5433, чтобы не конфликтовать с локально установленным PostgreSQL на 5432
POSTGRES_PORT=5433

# Connection string used by Prisma / API
DATABASE_URL="postgresql://ailin:ailin@localhost:5433/ailin_cinema?schema=public"

# --- API ---
API_PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# --- Web ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000
